# === Bybit API ===
BYBIT_API_KEY=your_key
BYBIT_API_SECRET=your_secret
TESTNET=False
BYBIT_DEMO=True

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHANNEL=your_channel_id

# === Grid Settings (optional, defaults shown) ===
# GRID_SYMBOL=ETHUSDT
# GRID_UPPER=0          # 0 = auto (current_price + 3%)
# GRID_LOWER=0          # 0 = auto (current_price - 3%)
# GRID_RANGE_PCT=3.0    # Auto range ±3%
# GRID_COUNT=10          # Number of grid levels
# GRID_INVESTMENT=0      # 0 = use full balance
# GRID_LEVERAGE=3        # Leverage multiplier
# GRID_MODE=neutral      # neutral / long_bias / short_bias
# MAX_DRAWDOWN_PCT=15.0  # Stop at -15%
