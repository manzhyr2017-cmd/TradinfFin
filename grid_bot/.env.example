# === Bybit API ===
BYBIT_API_KEY=your_key
BYBIT_API_SECRET=your_secret
TESTNET=False
BYBIT_DEMO=True

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHANNEL=your_channel_id

# === Grid Settings (optional, defaults shown) ===
# GRID_SYMBOL=AUTO        # AUTO = Scanner finds volatile pairs
# GRID_RANGE_PCT=10.0      # ±10% range
# GRID_COUNT=10
# GRID_INVESTMENT=0      # 0 = use ALLOCATION_PER_GRID (30% by default)
# GRID_LEVERAGE=3
# GRID_MODE=neutral

# === Advanced Logic ===
# RSI_ENTRY_CHECK=True
# USE_ATR_STEP=True
# AUTO_COMPOUND=False
# MAX_DRAWDOWN_PCT=15.0
# GRID_INACTIVITY_CLOSE_HOURS=24
# MAX_SYMBOLS_PER_SECTOR=2
# PROFIT_TRAIILING_THRESHOLD=5.0
# PROFIT_DRAWDOWN_CUTOFF=20.0
# FLASH_CRASH_PROTECTION=True
